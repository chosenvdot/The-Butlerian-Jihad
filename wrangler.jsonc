{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "victorbrasil",
  "compatibility_date": "2026-06-03",
  "compatibility_flags": ["nodejs_compat"],
  "build": {
    "command": "node node_modules/vite/bin/vite.js build"
  },
  "assets": {
    "directory": "./dist",
    "not_found_handling": "single-page-application"
  },
  "observability": {
    "enabled": true
  }
}
